        </div>
      )}

      {/* Rest-day card replaces the exercises list */}
      {dayIsRest ? (
        <div style={{ ...sx.card, padding:"24px 16px", marginBottom:14, textAlign:"center" }}>
          <div style={{ fontSize:32, marginBottom:8 }}>💤</div>
          <div style={{ fontWeight:700, fontSize:14, color:c.tp, marginBottom:4 }}>Rest day</div>
          <div style={{ fontSize:12, color:c.ts, lineHeight:1.5, marginBottom:14 }}>
            {dayExercises.length > 0
              ? `${dayExercises.length} exercise${dayExercises.length !== 1 ? "s" : ""} hidden. Tap "Rest day" again to unmark.`
              : "Take it easy. Body weight can still be logged below."}
          </div>
          <button onClick={toggleRest} style={{
            padding:"8px 18px", borderRadius:8,
            border:`1px solid ${c.inputBorder}`, background:c.inputBg,
            color:c.tp, fontSize:12, fontWeight:700, cursor:"pointer",
          }}>Unmark rest</button>
        </div>
      ) : (
        <>
          {dayExercises.length > 0 && (
            <div style={{ ...sx.cardSm, padding:"10px 12px", marginBottom:14 }}>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom: showLegend ? 8 : 0, cursor:"pointer" }} onClick={() => setShowLegend(s => !s)}>
