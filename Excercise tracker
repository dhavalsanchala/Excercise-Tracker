function RestTimer({ onClose }) {
  const [target, setTarget] = useState(120);
  const [remaining, setRemaining] = useState(120);
  const [running, setRunning] = useState(true);
  const startedAt = useRef(Date.now());
  const initial = useRef(120);

  useEffect(() => {
    if (!running) return;
    const id = setInterval(() => {
      const elapsed = Math.floor((Date.now() - startedAt.current) / 1000);
      const left = initial.current - elapsed;
      if (left <= 0) {
        setRemaining(0); setRunning(false);
        haptic([100, 50, 100, 50, 100]);
        clearInterval(id);
      } else setRemaining(left);
    }, 250);
    return () => clearInterval(id);
  }, [running]);

  const pickPreset = (s) => {
    setTarget(s); initial.current = s; setRemaining(s);
    startedAt.current = Date.now(); setRunning(true); haptic(8);
  };

  const fmt = (s) => `${Math.floor(s/60)}:${String(s%60).padStart(2,"0")}`;
  const pct = remaining / target;

  return (
    <div style={{
      position:"fixed", bottom:14, left:14, right:14, zIndex:50,
      ...sx.card, padding:"12px 14px", maxWidth:452, margin:"0 auto",
      boxShadow:"0 4px 20px rgba(0,0,0,0.5)",
    }}>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:8 }}>
        <div style={{ display:"flex", alignItems:"baseline", gap:8 }}>
          <span style={{ fontSize:22, fontWeight:700, color: remaining === 0 ? c.success : c.tp, fontVariantNumeric:"tabular-nums" }}>{fmt(remaining)}</span>
          <span style={{ fontSize:11, color:c.tm, fontWeight:600 }}>
            {remaining === 0 ? "READY" : running ? "rest" : "paused"}
          </span>
        </div>
        <button onClick={onClose} style={{ ...sx.btnGhost, fontSize:18, padding:"0 4px", lineHeight:1 }}>×</button>
      </div>
      <div style={{ height:3, background:"#2a2a2a", borderRadius:4, overflow:"hidden", marginBottom:10 }}>
        <div style={{ height:"100%", width:`${Math.max(0, pct*100)}%`, background: remaining === 0 ? c.success : c.accent, transition:"width 0.25s linear", borderRadius:4 }}/>
      </div>
      <div style={{ display:"flex", gap:5 }}>
        {[60, 90, 120, 180].map(s => (
          <button key={s} onClick={() => pickPreset(s)} style={{
            flex:1, padding:"6px 0", borderRadius:8,
            border:`1px solid ${target === s ? c.accent : c.inputBorder}`,
            background: target === s ? c.accent+"20" : "transparent",
            color: target === s ? c.accent : c.ts,
            fontSize:11, fontWeight:700, cursor:"pointer",
          }}>{s < 60 ? `${s}s` : `${s/60}m`}</button>
        ))}
        <button onClick={() => { setRunning(r => !r); haptic(8); }} style={{
          flex:1, padding:"6px 0", borderRadius:8,
          border:`1px solid ${c.inputBorder}`, background:c.inputBg,
          color:c.tp, fontSize:11, fontWeight:700, cursor:"pointer",
        }}>{running ? "‖" : "▶"}</button>
      </div>
    </div>
  );
}

