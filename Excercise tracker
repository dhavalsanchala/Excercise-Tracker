      {/* Rest-day toggle row */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10, gap:8 }}>
        <div style={{ fontSize:12, color:c.ts, flex:1, minWidth:0 }}>
          {dayIsRest
            ? <span style={{ color:c.tm, fontWeight:600 }}>Rest day</span>
