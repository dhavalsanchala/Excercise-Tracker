class ErrorBoundary extends Component {
  constructor(p) { super(p); this.state = { err: null }; }
  static getDerivedStateFromError(err) { return { err }; }
  reset = async () => {
    if (!confirm("Reset all data? This cannot be undone.")) return;
    await clearStore(); location.reload();
  };
  render() {
    if (!this.state.err) return this.props.children;
    return (
      <div style={{ minHeight:"100vh", background:c.bg, color:c.tp, padding:24, fontFamily:"-apple-system,sans-serif", maxWidth:480, margin:"0 auto" }}>
        <div style={{ ...sx.card, border:`1px solid ${c.danger}`, padding:20 }}>
          <div style={{ fontSize:18, fontWeight:700, color:c.danger, marginBottom:8 }}>Something broke</div>
          <div style={{ fontSize:13, color:c.ts, marginBottom:14, lineHeight:1.5 }}>
            The app hit an error and stopped. Your data is safe in storage. You can reload, or reset all data if it looks corrupted.
          </div>
          <pre style={{ fontSize:11, color:c.tm, background:c.inputBg, padding:10, borderRadius:8, overflowX:"auto", marginBottom:14 }}>
            {String(this.state.err?.message || this.state.err)}
          </pre>
          <div style={{ display:"flex", gap:8 }}>
            <button onClick={() => location.reload()} style={{ flex:1, padding:"10px", borderRadius:10, border:`1.5px solid ${c.accent}`, background:c.accent+"20", color:c.accent, fontSize:13, fontWeight:700, cursor:"pointer" }}>Reload</button>
            <button onClick={this.reset} style={{ flex:1, padding:"10px", borderRadius:10, border:`1.5px solid ${c.danger}`, background:c.danger+"20", color:c.danger, fontSize:13, fontWeight:700, cursor:"pointer" }}>Reset data</button>
          </div>
        </div>
      </div>
    );
  }
}

