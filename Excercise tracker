          }}>
            <div style={{ fontWeight:700, fontSize:13 }}>Bring forward exercises</div>
            <div style={{ fontSize:11, color:c.ts, marginTop:3 }}>Copy plan + tech from another week</div>
          </button>

          {/* Reset week */}
          <button onClick={() => setStep("reset-confirm")} style={{
            width:"100%", textAlign:"left", padding:"12px 14px",
            background:c.danger+"15", border:`1px solid ${c.danger}50`, borderRadius:10,
            color:c.danger, cursor:"pointer",
          }}>
            <div style={{ fontWeight:700, fontSize:13 }}>Reset this week</div>
            <div style={{ fontSize:11, color:c.ts, marginTop:3 }}>Clear all logged sets + measurements</div>
          </button>
        </div>
      </div>
    );
  }

  // ── Step: confirm reset ──
  if (step === "reset-confirm") {
    return (
      <div onClick={e => { if (e.target === e.currentTarget) onClose(); }} style={sx.modalBackdrop}>
        <div style={sx.modalSheet}>
          <div style={{ fontSize:15, fontWeight:700, color:c.danger, marginBottom:8 }}>Reset week?</div>
          <div style={{ fontSize:13, color:c.ts, marginBottom:14, lineHeight:1.5 }}>
            This clears all logged sets and body measurements for {formatWeekRange(currentWeek)}. The week's plan stays intact. This can't be undone.
          </div>
          <div style={{ display:"flex", gap:8 }}>
            <button onClick={() => setStep("menu")} style={{ ...sx.pickerCancel, flex:1, padding:"10px" }}>Cancel</button>
            <button onClick={() => { onResetWeek(currentWeek); haptic(15); onClose(); }} style={{
              flex:1, padding:"10px", borderRadius:10, border:"none",
              background:c.danger, color:"#000", fontSize:13, fontWeight:700, cursor:"pointer",
            }}>Reset</button>
          </div>
        </div>
      </div>
    );
  }

  // ── Step: pick source week for bring-forward ──
  if (step === "bring-forward") {
    const candidates = weeksWithData.filter(wk => wk !== currentWeek);
    return (
      <div onClick={e => { if (e.target === e.currentTarget) onClose(); }} style={sx.modalBackdrop}>
        <div style={sx.modalSheet}>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:14 }}>
            <div style={{ fontSize:15, fontWeight:700, color:c.tp }}>Copy from which week?</div>
            <button onClick={() => setStep("menu")} style={sx.pickerCancel}>Back</button>
          </div>
          <div style={{ fontSize:11, color:c.tm, marginBottom:14 }}>
            Copies exercise names + technique. Recent best weights become the new targets.
          </div>
          {candidates.length === 0 && (
            <div style={{ color:c.tm, fontSize:13, textAlign:"center", padding:"20px 0" }}>No other weeks have data yet</div>
          )}
          <div style={{ maxHeight:300, overflowY:"auto" }}>
            {candidates.map(wk => (
              <button key={wk} onClick={() => { onBringForward(wk, currentWeek); haptic(15); onClose(); }} style={{
                width:"100%", textAlign:"left", padding:"10px 12px", marginBottom:6,
                background:c.inputBg, border:`1px solid ${c.inputBorder}`, borderRadius:10,
                color:c.tp, cursor:"pointer",
              }}>
                <div style={{ fontWeight:700, fontSize:13 }}>{formatWeekRange(wk)}</div>
                <div style={{ fontSize:11, color:c.ts, marginTop:2 }}>{wk}</div>
              </button>
            ))}
          </div>
        </div>
      </div>
    );
  }

  // ── Step: pick a week to switch to ──
  if (step === "week-picker") {
    // Use a date input — easiest for arbitrary picking
    return (
      <div onClick={e => { if (e.target === e.currentTarget) onClose(); }} style={sx.modalBackdrop}>
        <div style={sx.modalSheet}>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:14 }}>
            <div style={{ fontSize:15, fontWeight:700, color:c.tp }}>Switch to week</div>
            <button onClick={() => setStep("menu")} style={sx.pickerCancel}>Back</button>
          </div>
          <div style={{ fontSize:11, color:c.tm, marginBottom:14 }}>Pick any date — its week (Mon–Sun) will load.</div>
          <input
            type="date"
            onChange={e => {
              if (!e.target.value) return;
              const wk = getWeekKeyFromDateKey(e.target.value);
              setPickedWk(wk);
            }}
            style={{ ...sx.input, width:"100%", boxSizing:"border-box", marginBottom:12 }}
          />
          {pickedWk && pickedWk !== currentWeek && (
            <div style={{ ...sx.cardSm, padding:"10px 12px", marginBottom:12 }}>
              <div style={{ fontSize:12, color:c.ts }}>Week:</div>
              <div style={{ fontWeight:700, fontSize:14, color:c.tp, marginTop:2 }}>{formatWeekRange(pickedWk)}</div>
            </div>
          )}
          <div style={{ display:"flex", gap:8 }}>
            <button onClick={() => setStep("menu")} style={{ ...sx.pickerCancel, flex:1, padding:"10px" }}>Cancel</button>
            <button
              disabled={!pickedWk || pickedWk === currentWeek}
              onClick={() => { onSetWeek(pickedWk); haptic(8); onClose(); }}
              style={{
                flex:1, padding:"10px", borderRadius:10, border:"none",
                background: !pickedWk || pickedWk === currentWeek ? c.inputBorder : c.accent,
                color:"#000", fontSize:13, fontWeight:700,
                cursor: !pickedWk || pickedWk === currentWeek ? "default" : "pointer",
                opacity: !pickedWk || pickedWk === currentWeek ? 0.5 : 1,
              }}>Go</button>
          </div>
        </div>
      </div>
    );
  }

  return null;
}

