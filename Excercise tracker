            value={day.measurements.bodyWeight || ""}
            onChange={e => updateMeasurement(activeDateKey, "bodyWeight", e.target.value)}
            style={{ ...sx.input, flex:1 }} />
          <span style={{ fontSize:13, color:c.ts, fontWeight:600 }}>kg</span>
