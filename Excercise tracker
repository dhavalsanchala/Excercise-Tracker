// ── ISO week helpers (Mon-anchored, matching DAYS order) ────────
// Week keys look like "2026-W18". Algorithm: ISO 8601 — week 1 contains the year's first Thursday.
function getISOWeek(date) {
  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  // Thursday in current week determines the year
  const dayNum = (d.getUTCDay() + 6) % 7; // Mon=0..Sun=6
  d.setUTCDate(d.getUTCDate() - dayNum + 3);
  const firstThursday = new Date(Date.UTC(d.getUTCFullYear(), 0, 4));
  const diff = (d - firstThursday) / 86400000;
  const week = 1 + Math.round((diff - 3 + ((firstThursday.getUTCDay() + 6) % 7)) / 7);
  return { year: d.getUTCFullYear(), week };
}
const weekKey = ({year, week}) => `${year}-W${String(week).padStart(2,"0")}`;
const getWeekKeyFromDate = (date) => weekKey(getISOWeek(date));
const getWeekKeyFromDateKey = (dk) => { const {y,m,d} = parseDateKey(dk); return getWeekKeyFromDate(new Date(y,m,d)); };

// Monday of the ISO week (returned as a {y,m,d})
function mondayOfISOWeek(year, week) {
  const jan4 = new Date(Date.UTC(year, 0, 4));
  const jan4Dow = (jan4.getUTCDay() + 6) % 7; // Mon=0
  const mondayWeek1 = new Date(Date.UTC(year, 0, 4 - jan4Dow));
  const monday = new Date(mondayWeek1);
  monday.setUTCDate(mondayWeek1.getUTCDate() + (week - 1) * 7);
  return { y: monday.getUTCFullYear(), m: monday.getUTCMonth(), d: monday.getUTCDate() };
}
function parseWeekKey(wk) {
  const [yStr, wStr] = wk.split("-W");
  return { year: parseInt(yStr,10), week: parseInt(wStr,10) };
}
// All 7 dateKeys (Mon..Sun) for a given week key
function weekDateKeys(wk) {
  const { year, week } = parseWeekKey(wk);
  const mon = mondayOfISOWeek(year, week);
  const start = new Date(Date.UTC(mon.y, mon.m, mon.d));
  const out = [];
  for (let i = 0; i < 7; i++) {
    const dt = new Date(start);
    dt.setUTCDate(start.getUTCDate() + i);
    out.push(dateKey(dt.getUTCFullYear(), dt.getUTCMonth(), dt.getUTCDate()));
  }
  return out;
}
// Adjacent weeks
function shiftWeekKey(wk, delta) {
  const { year, week } = parseWeekKey(wk);
  const mon = mondayOfISOWeek(year, week);
  const dt = new Date(Date.UTC(mon.y, mon.m, mon.d + delta * 7));
  return getWeekKeyFromDate(new Date(dt.getUTCFullYear(), dt.getUTCMonth(), dt.getUTCDate()));
}
// Human-friendly week label, e.g. "Apr 27 – May 3, 2026"
function formatWeekRange(wk) {
  const keys = weekDateKeys(wk);
  const a = parseDateKey(keys[0]), b = parseDateKey(keys[6]);
  const fmt = (p) => `${MONTHS[p.m]} ${p.d}`;
  return a.y === b.y
    ? `${fmt(a)} – ${fmt(b)}, ${a.y}`
    : `${fmt(a)}, ${a.y} – ${fmt(b)}, ${b.y}`;
}
// Compact version for tight UI — drops the year if it matches the current year
function formatWeekRangeCompact(wk) {
  const keys = weekDateKeys(wk);
  const a = parseDateKey(keys[0]), b = parseDateKey(keys[6]);
  const fmt = (p) => `${MONTHS[p.m]} ${p.d}`;
  const currentYear = new Date().getFullYear();
  if (a.y === b.y && a.y === currentYear) return `${fmt(a)} – ${fmt(b)}`;
  return formatWeekRange(wk);
}

