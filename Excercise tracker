function WorkoutView({ store, selDay, setSelDay, selDate, setSelDate, activeDateKey, todayStr, updateExercise, updateMeasurement, getPrevDK, restTimer, setRestTimer, showLegend, setShowLegend, addExerciseToDay, removeExerciseFromDay, setDayFocus, setDayRest, calendarOpen, setCalendarOpen }) {
