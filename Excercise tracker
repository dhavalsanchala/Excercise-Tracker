// FILE: hooks/useStore.js
// ═══════════════════════════════════════════════════════════════════

function useStore() {
  const [store, setStore] = useState({ __version: SCHEMA_VERSION, weeks: {}, days: {} });
  const [loadState, setLoadState] = useState("loading");

  useEffect(() => {
    loadStore().then(s => {
      if (s === null) { setLoadState("error"); return; }
      setStore(s); setLoadState("ready");
    });
  }, []);

  const updateExercise = useCallback((dk, name, exData) => {
    setStore(prev => {
      const day = prev.days[dk] || { exercises:{}, measurements:{} };
      const next = { ...prev, days: { ...prev.days, [dk]: { ...day, exercises: { ...day.exercises, [name]: exData } } } };
      saveStore(next); return next;
    });
  }, []);

  const updateMeasurement = useCallback((dk, key, val) => {
    setStore(prev => {
      const day = prev.days[dk] || { exercises:{}, measurements:{} };
      const next = { ...prev, days: { ...prev.days, [dk]: { ...day, measurements: { ...day.measurements, [key]: val } } } };
      saveStore(next); return next;
    });
  }, []);

  // Set/replace the plan for a specific week
  const setWeekPlan = useCallback((wk, plan) => {
    setStore(prev => {
      const next = { ...prev, weeks: { ...prev.weeks, [wk]: { ...(prev.weeks?.[wk] || {}), plan } } };
      saveStore(next); return next;
    });
  }, []);

  // Set the focus label for a (week, day). Pass null to clear back to default.
  const setDayFocus = useCallback((wk, dow, label) => {
    setStore(prev => {
      const weekEntry = prev.weeks?.[wk] || {};
      const focusMap = { ...(weekEntry.focus || {}) };
      if (label == null) delete focusMap[dow];
      else focusMap[dow] = label;
      const next = { ...prev, weeks: { ...prev.weeks, [wk]: { ...weekEntry, focus: focusMap } } };
      saveStore(next); return next;
    });
  }, []);

  // Set rest-day flag for a (week, day). Pass null to clear back to default.
  const setDayRest = useCallback((wk, dow, isRest) => {
    setStore(prev => {
      const weekEntry = prev.weeks?.[wk] || {};
      const restMap = { ...(weekEntry.rest || {}) };
      if (isRest == null) delete restMap[dow];
      else restMap[dow] = !!isRest;
      const next = { ...prev, weeks: { ...prev.weeks, [wk]: { ...weekEntry, rest: restMap } } };
      saveStore(next); return next;
    });
  }, []);

  // Add a single exercise to a specific (week, day)
  const addExerciseToDay = useCallback((wk, dow, exercise) => {
    setStore(prev => {
      const currentPlan = prev.weeks?.[wk]?.plan || WORKOUT_PLAN;
      // Snapshot the plan into this week so future changes don't affect other weeks
      const snapshotPlan = {};
      for (const d of DAYS) snapshotPlan[d] = [...(currentPlan[d] || [])];
      // Strip the seed-only fields from what we store on the plan; the plan only
      // remembers name + target. plannedSets/plannedRir/tech are realized into day records.
      snapshotPlan[dow] = [
        ...snapshotPlan[dow],
        { name: exercise.name, target: exercise.target },
      ];

      // Pre-create empty sets on every day-of-week date in this week that matches `dow`.
      // Skip days that already have any data for this exercise (don't clobber logged sets).
      const newDays = { ...prev.days };
      const plannedSets = exercise.plannedSets || 0;
      const plannedRir = exercise.plannedRir == null ? "" : String(exercise.plannedRir);
      const tech = exercise.tech || null;

      if (plannedSets > 0 || tech) {
        for (const dk of weekDateKeys(wk)) {
          if (getDOWFromKey(dk) !== dow) continue;
          const day = newDays[dk] || { exercises: {}, measurements: {} };
          // Don't overwrite existing logged data
          if (day.exercises?.[exercise.name]) continue;
          const seededSets = [];
          for (let i = 0; i < plannedSets; i++) {
            seededSets.push({ weight:"", reps:"", rir: plannedRir, tech:null, done:false });
          }
          newDays[dk] = {
            ...day,
            exercises: {
              ...day.exercises,
              [exercise.name]: { sets: seededSets, tech, supersetWith: null },
            },
          };
        }
      }

      const next = {
        ...prev,
        weeks: { ...prev.weeks, [wk]: { ...(prev.weeks?.[wk] || {}), plan: snapshotPlan } },
        days: newDays,
      };
      saveStore(next); return next;
    });
  }, []);

  // Remove an exercise from a specific (week, day) — also clears its logged sets that week
  const removeExerciseFromDay = useCallback((wk, dow, exName) => {
    setStore(prev => {
      const currentPlan = prev.weeks?.[wk]?.plan || WORKOUT_PLAN;
      const snapshotPlan = {};
      for (const d of DAYS) snapshotPlan[d] = [...(currentPlan[d] || [])];
      snapshotPlan[dow] = snapshotPlan[dow].filter(e => e.name !== exName);

      const newDays = { ...prev.days };
      for (const dk of weekDateKeys(wk)) {
        if (getDOWFromKey(dk) === dow && newDays[dk]?.exercises?.[exName]) {
          const day = { ...newDays[dk], exercises: { ...newDays[dk].exercises } };
          delete day.exercises[exName];
          newDays[dk] = day;
        }
      }
      const next = { ...prev, weeks: { ...prev.weeks, [wk]: { ...(prev.weeks?.[wk] || {}), plan: snapshotPlan } }, days: newDays };
      saveStore(next); return next;
    });
  }, []);

  // Reset a whole week: clear all exercise sets + body measurements for those 7 days
  const resetWeek = useCallback((wk) => {
    setStore(prev => {
      const newDays = { ...prev.days };
      for (const dk of weekDateKeys(wk)) delete newDays[dk];
      const next = { ...prev, days: newDays };
      saveStore(next); return next;
    });
  }, []);

  // Bring forward: copy plan (names + tech) from sourceWk into targetWk,
  // setting each exercise's `target` to the most recent weight logged for it (across history).
  const bringForwardWeek = useCallback((sourceWk, targetWk) => {
    setStore(prev => {
      const sourcePlan = prev.weeks?.[sourceWk]?.plan || WORKOUT_PLAN;

      // Build a name → most-recent-weight map (looking strictly at dates ≤ source week's last day)
      const sourceLastDk = weekDateKeys(sourceWk)[6];
      const recentWeightByName = {};
      const sortedDks = Object.keys(prev.days).filter(k => k <= sourceLastDk).sort();
      for (const dk of sortedDks) {
        const exs = prev.days[dk]?.exercises || {};
        for (const [name, ex] of Object.entries(exs)) {
          const best = (ex.sets || []).reduce((a, s) => Math.max(a, num(s.weight)), 0);
          if (best > 0) recentWeightByName[name] = best;
        }
      }

      // Snapshot source plan into target week, replacing target reps with last weight
      const newPlan = {};
      for (const d of DAYS) {
        newPlan[d] = (sourcePlan[d] || []).map(ex => ({
          name: ex.name,
          target: recentWeightByName[ex.name] ?? ex.target,
        }));
      }
      // Also carry forward each exercise's default tech (per day) by pre-seeding day records
      const newDays = { ...prev.days };
      for (const dk of weekDateKeys(targetWk)) {
        const dow = getDOWFromKey(dk);
        const day = newDays[dk] || { exercises: {}, measurements: {} };
        const exs = { ...day.exercises };
        for (const ex of (sourcePlan[dow] || [])) {
          // Find this exercise's most recent tech in source week
          let tech = null;
          for (const sdk of weekDateKeys(sourceWk)) {
            if (getDOWFromKey(sdk) === dow) {
              const t = prev.days[sdk]?.exercises?.[ex.name]?.tech;
              if (t) tech = t;
            }
          }
          // Only seed if no entry exists yet (don't overwrite logged data)
          if (!exs[ex.name] && tech) {
            exs[ex.name] = { sets: [], tech, supersetWith: null };
          }
        }
        if (Object.keys(exs).length !== Object.keys(day.exercises || {}).length) {
          newDays[dk] = { ...day, exercises: exs };
        }
      }

      const next = {
        ...prev,
        weeks: { ...prev.weeks, [targetWk]: { ...(prev.weeks?.[targetWk] || {}), plan: newPlan } },
        days: newDays,
      };
      saveStore(next); return next;
    });
  }, []);

  // Start a blank week: explicit empty plan { MON:[], TUE:[], ..., SUN:[] }
  const startBlankWeek = useCallback((wk) => {
    const blank = {};
    for (const d of DAYS) blank[d] = [];
    setWeekPlan(wk, blank);
  }, [setWeekPlan]);

  const replaceStore = useCallback(async (raw) => {
    const migrated = migrateToLatest(raw);
    await saveStore(migrated);
    setStore(migrated);
  }, []);

  return {
    store, loadState,
    updateExercise, updateMeasurement,
    setWeekPlan, addExerciseToDay, removeExerciseFromDay,
    setDayFocus, setDayRest,
    resetWeek, bringForwardWeek, startBlankWeek,
    replaceStore,
  };
}

