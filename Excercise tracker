const todayDay = () => { const d = new Date().getDay(); const map = [6,0,1,2,3,4,5]; return DAYS[map[d]] || "MON"; };
const dateKey = (y,m,d) => `${y}-${String(m+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
const parseDateKey = (k) => { const [y,m,d] = k.split("-").map(Number); return { y, m: m-1, d }; };
const getDOWFromKey = (k) => { const { y,m,d } = parseDateKey(k); const day = new Date(y,m,d).getDay(); const map = [6,0,1,2,3,4,5]; return DAYS[map[day]] || "MON"; };
const num = (v) => { const n = parseFloat(v); return Number.isFinite(n) ? n : 0; };
