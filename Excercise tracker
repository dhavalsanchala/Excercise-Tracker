function ProgressView({ store, progressDay, setProgressDay, progressEx, setProgressEx, dateKeyIndex, todayStr }) {
  const todayWeek = getWeekKeyFromDateKey(todayStr);
  const planForToday = getPlanForWeek(store, todayWeek);
  const dayExercises = planForToday[progressDay] || [];

  return (
    <>
      <DayPills selected={progressDay} onSelect={d => { setProgressDay(d); setProgressEx(null); }} dimRest />
      {dayExercises.length === 0 && <div style={{ color:c.ts, fontSize:13, textAlign:"center", padding:"30px 0" }}>No exercises planned for this day</div>}
      {dayExercises.map(ex => {
        const isOpen = progressEx === ex.name;
        const sessionKeys = dateKeyIndex[progressDay] || [];
        const sessions = sessionKeys.map(k => [k, getDay(store, k)]);
        const logged = sessions.filter(([,d]) => d.exercises[ex.name]?.sets?.length > 0).length;
        const allBests = sessions.map(([,d]) => Math.max(0, ...(d.exercises[ex.name]?.sets || []).map(s => num(s.weight)))).filter(v => v > 0);
        const pb = allBests.length ? Math.max(...allBests) : 0;
        const chartPts = sessions.map(([k,d]) => {
          const sets = d.exercises[ex.name]?.sets || [];
          const best = Math.max(0, ...sets.map(s => num(s.weight)));
          return best > 0 ? { date:k, val:best } : null;
        }).filter(Boolean);
        const lastTech = sessions.map(([,d]) => d.exercises[ex.name]?.tech).filter(Boolean).slice(-1)[0];
        const lastTechObj = TECH_BY_KEY[lastTech];
        return (
          <div key={ex.name} style={{ ...sx.card, borderLeft:`3px solid ${DAY_COLORS[progressDay]}`, overflow:"hidden", marginBottom:8 }}>
            <div onClick={() => setProgressEx(isOpen ? null : ex.name)} style={{ cursor:"pointer", display:"flex", justifyContent:"space-between", alignItems:"center", padding:"12px 14px" }}>
              <div>
                <div style={{ display:"flex", alignItems:"center", gap:6, flexWrap:"wrap" }}>
                  <span style={{ fontWeight:700, fontSize:13, color:c.tp }}>{ex.name}</span>
                  {lastTechObj && <span style={sx.pill(lastTechObj.color)}>{lastTechObj.short}</span>}
                </div>
                <div style={{ fontSize:11, color:c.ts, marginTop:3 }}>{logged} session{logged !== 1 ? "s" : ""} logged</div>
              </div>
              <div style={{ textAlign:"right" }}>
                {pb > 0 && <div style={{ fontSize:14, fontWeight:700, color:c.warning }}>{pb}kg PB</div>}
                <div style={{ fontSize:11, color:c.ts, marginTop:2 }}>{isOpen ? "▲ hide" : "▼ chart"}</div>
              </div>
            </div>
            {isOpen && (
              <div style={{ padding:"0 14px 14px", borderTop:`1px solid ${c.div}` }}>
                <div style={{ paddingTop:12 }}>
                  <SectionLabel>Best weight per session (kg)</SectionLabel>
                  <MiniChart points={chartPts} color={DAY_COLORS[progressDay]} height={64} />
                </div>
                {sessions.slice(-3).reverse().map(([k,d]) => {
                  const exD = d.exercises[ex.name];
                  if (!exD?.sets?.length) return null;
                  const exTechObj = TECH_BY_KEY[exD.tech];
                  return (
                    <div key={k} style={{ marginTop:8, background:c.inputBg, border:`1px solid ${c.inputBorder}`, borderRadius:10, padding:"10px 12px" }}>
                      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:6 }}>
                        <span style={{ fontSize:11, color:c.ts, fontWeight:600 }}>{k}</span>
                        {exTechObj && <span style={sx.pill(exTechObj.color)}>{exTechObj.short}</span>}
                      </div>
                      {exD.sets.map((ss, i) => {
                        const ssTechObj = TECH_BY_KEY[ss.tech];
                        return (
                          <div key={i} style={{ display:"flex", gap:10, fontSize:12, marginBottom:3, alignItems:"center" }}>
                            <span style={{ color:c.ts, width:22, fontWeight:600 }}>S{i+1}</span>
                            <span style={{ color:c.tp, fontWeight:700 }}>{ss.weight||"—"}kg</span>
                            <span style={{ color:c.ts }}>{ss.reps||"—"} reps</span>
                            <span style={{ color:c.ts }}>RIR {ss.rir!==""&&ss.rir!=null?ss.rir:"—"}</span>
                            {ssTechObj && <span style={{ ...sx.pill(ssTechObj.color), fontSize:9, padding:"1px 5px" }}>{ssTechObj.short}</span>}
                          </div>
                        );
                      })}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        );
      })}
    </>
  );
}

