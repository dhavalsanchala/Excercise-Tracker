const SETS_VALS = Array.from({ length: 21 }, (_, i) => i);              // 0–20

function PickerModal({ field, currentValue, onConfirm, onClose, color }) {
  const parseW = (v) => {
    if (v === "" || v == null) return { base:0, fine:0 };
    const n = num(v); const base = Math.floor(n / 5) * 5;
    return { base, fine: parseFloat((n - base).toFixed(1)) };
  };
  const initW = parseW(currentValue);
  const [wBase, setWBase] = useState(initW.base);
  const [wFine, setWFine] = useState(initW.fine);
  const [reps, setReps] = useState(parseInt(currentValue) || 1);
  const [rir, setRir] = useState(currentValue === "" || currentValue == null ? null : parseFloat(currentValue));

  const confirm = () => {
    haptic(8);
    if (field === "weight") onConfirm(String(parseFloat((wBase + wFine).toFixed(1))));
    else if (field === "reps") onConfirm(String(reps));
    else onConfirm(rir == null ? "" : String(rir));
    onClose();
  };

  const title = field === "weight" ? "Weight (kg)" : field === "reps" ? "Reps" : "Reps in Reserve";

  return (
    <div onClick={e => { if (e.target === e.currentTarget) onClose(); }} style={sx.modalBackdrop}>
      <div style={sx.modalSheet}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:20 }}>
          <div style={{ fontSize:15, fontWeight:700, color:c.tp }}>{title}</div>
          <div style={{ display:"flex", gap:10 }}>
            <button onClick={onClose} style={sx.pickerCancel}>Cancel</button>
            <button onClick={confirm} style={sx.pickerDone(color)}>Done</button>
          </div>
        </div>
        {field === "weight" && (
          <div>
            <div style={{ display:"flex", justifyContent:"center", gap:12, marginBottom:12 }}>
              <ScrollPicker values={WEIGHT_VALS} value={wBase} onChange={setWBase} width={100} label="Base (5kg)" />
              <div style={{ display:"flex", alignItems:"center", fontSize:20, color:c.ts, paddingTop:28 }}>+</div>
              <ScrollPicker values={FINE_VALS} value={wFine} onChange={setWFine} width={80} label="Fine (0.5kg)" />
            </div>
            <div style={{ textAlign:"center", fontSize:26, fontWeight:700, color }}>{parseFloat((wBase + wFine).toFixed(1))} kg</div>
          </div>
        )}
        {field === "reps" && (
          <div>
            <div style={{ display:"flex", justifyContent:"center", marginBottom:12 }}>
              <ScrollPicker values={REPS_VALS} value={reps} onChange={setReps} width={120} label="Reps" />
            </div>
            <div style={{ textAlign:"center", fontSize:26, fontWeight:700, color }}>{reps} reps</div>
          </div>
        )}
        {field === "rir" && (
          <div>
            <div style={{ display:"flex", justifyContent:"center", marginBottom:12 }}>
              <ScrollPicker values={RIR_VALS} value={rir == null ? 2 : rir} onChange={setRir} width={120} label="0 = failure" />
            </div>
            <div style={{ textAlign:"center", fontSize:26, fontWeight:700, color }}>
              {rir == null ? <span style={{ color:c.tm }}>Not set</span> : `RIR ${rir}`}
            </div>
            {rir == null && <div style={{ textAlign:"center", fontSize:11, color:c.tm, marginTop:6 }}>Scroll to set · 0 = couldn't do another rep</div>}
          </div>
        )}
      </div>
    </div>
  );
}

