// FILE: App.jsx — top-level shell + routing
// ═══════════════════════════════════════════════════════════════════

function AppInner() {
  const {
    store, loadState,
    updateExercise, updateMeasurement,
    setWeekPlan, addExerciseToDay, removeExerciseFromDay,
    setDayFocus, setDayRest,
    resetWeek, bringForwardWeek, startBlankWeek,
    replaceStore,
  } = useStore();

  const [view, setView] = useState("today");
  const [selDay, setSelDay] = useState(todayDay());
  const [selDate, setSelDate] = useState(null);
  const [progressDay, setProgressDay] = useState("MON");
  const [progressEx, setProgressEx] = useState(null);
  const [bodyDate, setBodyDate] = useState(dateKey(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()));
  const [openMeasure, setOpenMeasure] = useState(null);
  const [showLegend, setShowLegend] = useState(true);
  const [restTimer, setRestTimer] = useState(false);
  const [weekManagerOpen, setWeekManagerOpen] = useState(false);
  const [calendarOpen, setCalendarOpen] = useState(false);
  const [focusEditing, setFocusEditing] = useState(false);
  const [focusDraft, setFocusDraft] = useState("");

  const todayStr = dateKey(new Date().getFullYear(), new Date().getMonth(), new Date().getDate());
  const activeDateKey = selDate || todayStr;

  useEffect(() => {
    if (loadState === "ready" && Object.keys(store.days).length > 0) setShowLegend(false);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [loadState]);

  // Cancel inline focus edit if the user navigates away from the current day
  useEffect(() => { setFocusEditing(false); }, [selDay, selDate, view]);

  const measHistoryByKey = useMemo(() => {
    const res = {};
    for (const m of MEASUREMENTS) {
      res[m.key] = Object.entries(store.days)
        .filter(([,d]) => d.measurements?.[m.key] != null && d.measurements[m.key] !== "")
        .map(([k,d]) => ({ date:k, val: parseFloat(d.measurements[m.key]) }))
        .filter(p => !isNaN(p.val))
        .sort((a,b) => a.date.localeCompare(b.date));
    }
    return res;
  }, [store]);

  const dateKeyIndex = useMemo(() => {
    const byDOW = { MON:[], TUE:[], WED:[], THU:[], FRI:[], SAT:[], SUN:[] };
    Object.keys(store.days).forEach(k => { try { byDOW[getDOWFromKey(k)].push(k); } catch {} });
    Object.values(byDOW).forEach(arr => arr.sort());
    return byDOW;
  }, [store]);

  const getMeasHistory = (key) => measHistoryByKey[key] || [];

  const getPrevDK = useCallback((dayName) => {
    const arr = dateKeyIndex[dayName];
    if (!arr) return null;
    for (let i = arr.length - 1; i >= 0; i--) if (arr[i] < todayStr) return arr[i];
    return null;
  }, [dateKeyIndex, todayStr]);

  const exportData = () => {
    const blob = new Blob([JSON.stringify(store,null,2)], { type:"application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = `workout_${todayStr}.json`; a.click();
    URL.revokeObjectURL(url);
  };

  const importData = () => {
    const input = document.createElement("input");
    input.type = "file"; input.accept = ".json";
    input.onchange = async e => {
      const f = e.target.files[0]; if (!f) return;
      try {
        const raw = JSON.parse(await f.text());
        if (typeof raw !== "object" || raw == null) throw new Error("not an object");
        await replaceStore(raw);
        alert("✅ Restored!");
      } catch { alert("❌ Invalid file"); }
    };
    input.click();
  };

  if (loadState === "loading") {
    return (
      <div style={{ minHeight:"100vh", background:c.bg, color:c.tp, display:"flex", alignItems:"center", justifyContent:"center", flexDirection:"column", gap:14, fontFamily:"-apple-system,sans-serif" }}>
        <div style={{ width:32, height:32, border:`3px solid ${c.cardBorder}`, borderTopColor:c.accent, borderRadius:"50%", animation:"spin 0.8s linear infinite" }}/>
        <div style={{ color:c.ts, fontSize:13 }}>Loading workouts…</div>
        <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
      </div>
    );
  }

  if (loadState === "error") {
    return (
      <div style={{ minHeight:"100vh", background:c.bg, color:c.tp, padding:24, fontFamily:"-apple-system,sans-serif", maxWidth:480, margin:"0 auto" }}>
        <div style={{ ...sx.card, border:`1px solid ${c.danger}`, padding:20 }}>
          <div style={{ fontSize:16, fontWeight:700, color:c.danger, marginBottom:8 }}>Couldn't read your data</div>
          <div style={{ fontSize:13, color:c.ts, marginBottom:14, lineHeight:1.5 }}>
            Your saved data may be corrupted. You can reload to retry, or reset everything to start fresh.
          </div>
          <div style={{ display:"flex", gap:8 }}>
            <button onClick={() => location.reload()} style={{ flex:1, padding:"10px", borderRadius:10, border:`1.5px solid ${c.accent}`, background:c.accent+"20", color:c.accent, fontSize:13, fontWeight:700, cursor:"pointer" }}>Reload</button>
            <button onClick={async () => { if (confirm("Delete all data?")) { await clearStore(); location.reload(); } }}
              style={{ flex:1, padding:"10px", borderRadius:10, border:`1.5px solid ${c.danger}`, background:c.danger+"20", color:c.danger, fontSize:13, fontWeight:700, cursor:"pointer" }}>Reset</button>
          </div>
        </div>
      </div>
    );
  }

  const latestBW = (() => { const h = getMeasHistory("bodyWeight"); return h.length ? h[h.length-1] : null; })();
  const headerTitle = view === "body" ? "Body measurements" : view === "progress" ? "Progress" : "";
  const activeWeek = getWeekKeyFromDateKey(activeDateKey);
  const dayFocus = getDayFocus(store, activeWeek, selDay);

  const beginEditFocus = () => {
    setFocusDraft(dayFocus);
    setFocusEditing(true);
  };
  const commitFocus = () => {
    const trimmed = focusDraft.trim();
    // If the user clears it back to the default for that day, clear the override.
    if (trimmed === (DAY_FOCUS[selDay] || "")) setDayFocus(activeWeek, selDay, null);
    else setDayFocus(activeWeek, selDay, trimmed);
    setFocusEditing(false);
    haptic(8);
  };
  const cancelEditFocus = () => { setFocusEditing(false); };


  return (
    <div style={{ minHeight:"100vh", background:c.bg, color:c.tp, fontFamily:"-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif", maxWidth:480, margin:"0 auto", paddingBottom: restTimer ? 110 : 0 }}>
      <div style={sx.stickyHeader}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center" }}>
          <div style={{ minWidth:0, flex:1 }}>
            {view === "today" ? (
              focusEditing ? (
                <div style={{ display:"flex", alignItems:"center", gap:6, fontSize:17, fontWeight:700 }}>
                  <span style={{ color: DAY_COLORS[selDay] }}>{DAY_LABELS[selDay]} ·</span>
                  <input
                    autoFocus
                    value={focusDraft}
                    onChange={e => setFocusDraft(e.target.value)}
                    onBlur={commitFocus}
                    onKeyDown={e => {
                      if (e.key === "Enter") commitFocus();
                      if (e.key === "Escape") cancelEditFocus();
                    }}
                    placeholder="Focus…"
                    maxLength={24}
                    style={{
                      flex:1, minWidth:0,
                      background:c.inputBg, border:`1px solid ${c.accent}`,
                      borderRadius:6, padding:"3px 8px",
                      color:c.tp, fontSize:15, fontWeight:600, outline:"none",
                      fontFamily:"inherit",
                    }}
                  />
                </div>
              ) : (
                <button
                  onClick={beginEditFocus}
                  title="Tap to edit focus"
                  style={{
                    background:"none", border:"none", padding:0, cursor:"pointer",
                    fontWeight:700, fontSize:17, letterSpacing:-0.3,
                    color: DAY_COLORS[selDay], textAlign:"left",
                    whiteSpace:"nowrap", overflow:"hidden", textOverflow:"ellipsis",
                    maxWidth:"100%",
                    fontFamily:"inherit",
                  }}>
                  {DAY_LABELS[selDay]}{dayFocus ? ` · ${dayFocus}` : ""}
                  <span style={{ fontSize:10, color:c.tm, marginLeft:6, fontWeight:500 }}>✎</span>
                </button>
              )
            ) : (
              <div style={{ fontWeight:700, fontSize:17, color:c.tp, letterSpacing:-0.3, whiteSpace:"nowrap", overflow:"hidden", textOverflow:"ellipsis" }}>
                {headerTitle}
              </div>
            )}
            {view === "today" ? (
              <div style={{ display:"flex", alignItems:"center", gap:4, marginTop:3 }}>
                <button
                  onClick={() => {
                    const curWk = getWeekKeyFromDateKey(activeDateKey);
                    const newWk = shiftWeekKey(curWk, -1);
                    const wkDates = weekDateKeys(newWk);
                    // Land on today if it's in that week, else Monday
                    const target = wkDates.includes(todayStr) ? todayStr : wkDates[0];
                    setSelDate(target === todayStr ? null : target);
                    setSelDay(getDOWFromKey(target));
                    haptic(5);
                  }}
                  title="Previous week"
                  style={{ background:c.inputBg, border:`1px solid ${c.inputBorder}`, color:c.ts, fontSize:13, cursor:"pointer", padding:"2px 8px", borderRadius:6, lineHeight:1 }}
                >‹</button>
                <button onClick={() => { setCalendarOpen(o => !o); haptic(5); }} style={{
                  background:"none", border:"none", padding:"2px 4px",
                  color:c.ts, fontSize:12, fontWeight:600, cursor:"pointer",
                  display:"flex", alignItems:"center", gap:5,
                }}>
                  <span>{formatWeekRangeCompact(getWeekKeyFromDateKey(activeDateKey))}</span>
                  <span style={{ fontSize:10, transition:"transform 0.2s", transform: calendarOpen ? "rotate(180deg)" : "rotate(0)" }}>▾</span>
                </button>
                <button
                  onClick={() => {
                    const curWk = getWeekKeyFromDateKey(activeDateKey);
                    const newWk = shiftWeekKey(curWk, 1);
                    const wkDates = weekDateKeys(newWk);
                    const target = wkDates.includes(todayStr) ? todayStr : wkDates[0];
                    setSelDate(target === todayStr ? null : target);
                    setSelDay(getDOWFromKey(target));
                    haptic(5);
                  }}
                  title="Next week"
                  style={{ background:c.inputBg, border:`1px solid ${c.inputBorder}`, color:c.ts, fontSize:13, cursor:"pointer", padding:"2px 8px", borderRadius:6, lineHeight:1 }}
                >›</button>
              </div>
            ) : (
              latestBW && <div style={{ fontSize:12, color:c.accent, marginTop:2, fontWeight:600 }}>⚖ {latestBW.val}kg · {latestBW.date.slice(5)}</div>
            )}
          </div>
          <div style={{ display:"flex", gap:6, flexShrink:0 }}>
            {view === "today" && (
              <button onClick={() => { setWeekManagerOpen(true); haptic(8); }} title="Manage week" style={sx.headerBtn(c.tp, false)}>⚙</button>
            )}
            {view === "today" && getDayPlan(store, activeDateKey).length > 0 && (
              <button onClick={() => { setRestTimer(true); haptic(8); }} style={sx.headerBtn(c.accent, restTimer)}>⏱</button>
            )}
            <button onClick={exportData} style={sx.headerBtn(c.success, false)}>↓</button>
            <button onClick={importData} style={sx.headerBtn(c.accent, false)}>↑</button>
          </div>
        </div>
        <div style={{ display:"flex", gap:2, background:"#111", borderRadius:10, padding:3, marginTop:10, border:`1px solid ${c.cardBorder}` }}>
          {[["today","Workout"],["body","Body"],["progress","Progress"]].map(([v,l]) => (
            <button key={v} onClick={() => { setView(v); haptic(5); }} style={{ flex:1, padding:"8px 0", borderRadius:8, border:"none", background:view===v?"#2a2a2a":"transparent", color:view===v?c.tp:c.tm, fontSize:11, fontWeight:view===v?700:500, cursor:"pointer" }}>{l}</button>
          ))}
        </div>
      </div>

      <div style={{ padding:"14px 14px 80px" }}>
        {view === "today" && (
          <WorkoutView
            store={store} selDay={selDay} setSelDay={setSelDay} selDate={selDate} setSelDate={setSelDate}
            activeDateKey={activeDateKey} todayStr={todayStr}
            updateExercise={updateExercise} updateMeasurement={updateMeasurement} getPrevDK={getPrevDK}
            restTimer={restTimer} setRestTimer={setRestTimer}
            showLegend={showLegend} setShowLegend={setShowLegend}
            addExerciseToDay={addExerciseToDay} removeExerciseFromDay={removeExerciseFromDay}
            setDayFocus={setDayFocus} setDayRest={setDayRest}
            calendarOpen={calendarOpen} setCalendarOpen={setCalendarOpen}
          />
        )}
        {view === "body" && (
          <BodyView
            store={store} bodyDate={bodyDate} setBodyDate={setBodyDate}
            updateMeasurement={updateMeasurement}
            openMeasure={openMeasure} setOpenMeasure={setOpenMeasure}
            getMeasHistory={getMeasHistory}
          />
        )}
        {view === "progress" && (
          <ProgressView
            store={store} progressDay={progressDay} setProgressDay={setProgressDay}
            progressEx={progressEx} setProgressEx={setProgressEx} dateKeyIndex={dateKeyIndex}
            todayStr={todayStr}
          />
        )}
      </div>

      {restTimer && <RestTimer onClose={() => setRestTimer(false)} />}

      {weekManagerOpen && (
        <WeekManagerModal
          store={store}
          currentWeek={getWeekKeyFromDateKey(activeDateKey)}
          onClose={() => setWeekManagerOpen(false)}
          onResetWeek={resetWeek}
          onBringForward={bringForwardWeek}
          onStartBlank={startBlankWeek}
          onSetWeek={(wk) => {
            // Jump to Monday of that week, MON view
            const mondayKey = weekDateKeys(wk)[0];
            setSelDate(mondayKey);
            setSelDay("MON");
            setView("today");
          }}
        />
      )}
    </div>
  );
}

export default function App() {
  return <ErrorBoundary><AppInner /></ErrorBoundary>;
