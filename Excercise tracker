function BodyView({ store, bodyDate, setBodyDate, updateMeasurement, openMeasure, setOpenMeasure, getMeasHistory }) {
  return (
    <>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
        <div style={{ fontSize:13, fontWeight:600, color:c.ts }}>Logging for date</div>
        <input type="date" value={bodyDate} onChange={e => setBodyDate(e.target.value)} style={sx.inputSm} />
      </div>
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, marginBottom:18 }}>
        {MEASUREMENTS.slice(0,4).map(m => {
          const h = getMeasHistory(m.key);
          const latest = h.length ? h[h.length-1] : null;
          const prev = h.length > 1 ? h[h.length-2] : null;
          const diff = latest && prev ? (latest.val - prev.val).toFixed(1) : null;
          const diffColor = m.key === "bodyWeight"
            ? (parseFloat(diff) <= 0 ? c.success : c.danger)
            : (parseFloat(diff) >= 0 ? c.success : c.danger);
          return (
            <div key={m.key} style={{ ...sx.cardSm, padding:"12px 14px", borderTop:`3px solid ${m.color}` }}>
              <div style={{ fontSize:10, color:c.ts, marginBottom:4, fontWeight:600 }}>{m.label}</div>
              <div style={{ fontSize:22, fontWeight:700, color:c.tp, lineHeight:1 }}>
                {latest ? latest.val : <span style={{ color:c.tm }}>—</span>}
                <span style={{ fontSize:11, color:c.ts, marginLeft:3 }}>{m.unit}</span>
              </div>
              {diff != null && <div style={{ fontSize:11, color:diffColor, marginTop:5, fontWeight:600 }}>{parseFloat(diff) > 0 ? "+" : ""}{diff} {m.unit}</div>}
            </div>
          );
        })}
      </div>
      <SectionLabel>Log for {bodyDate}</SectionLabel>
      {MEASUREMENTS.map(m => {
        const isOpen = openMeasure === m.key;
        const history = getMeasHistory(m.key);
        const latest = history.length ? history[history.length-1] : null;
        return (
          <div key={m.key} style={{ ...sx.card, overflow:"hidden", marginBottom:8 }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", padding:"11px 14px", borderLeft:`3px solid ${m.color}` }}>
              <div>
                <div style={{ fontWeight:600, fontSize:13, color:c.tp }}>{m.label}</div>
                {latest
                  ? <div style={{ fontSize:11, color:c.ts, marginTop:2 }}>Last: <strong style={{ color:m.color }}>{latest.val}{m.unit}</strong> · {latest.date.slice(5)}</div>
                  : <div style={{ fontSize:11, color:c.tm, marginTop:2 }}>No data yet</div>}
              </div>
              <div style={{ display:"flex", gap:8, alignItems:"center" }}>
                <div style={{ display:"flex", alignItems:"center", gap:4, background:c.inputBg, border:`1px solid ${c.inputBorder}`, borderRadius:8, padding:"2px 8px" }}>
                  <input type="number" inputMode="decimal" step="0.1" min="0" placeholder="—"
                    value={getMeasurement(store, bodyDate, m.key)}
                    onChange={e => updateMeasurement(bodyDate, m.key, e.target.value)}
                    style={{ width:52, border:"none", background:"transparent", color:c.tp, fontSize:14, textAlign:"center", outline:"none", padding:"5px 0" }} />
                  <span style={{ fontSize:10, color:c.ts, fontWeight:600 }}>{m.unit}</span>
                </div>
                <button onClick={() => setOpenMeasure(isOpen ? null : m.key)} style={{ ...sx.btnGhost, color:isOpen ? m.color : c.tm, fontSize:14, padding:4, lineHeight:1, fontWeight:700 }}>{isOpen ? "▲" : "▼"}</button>
              </div>
            </div>
            {isOpen && history.length > 0 && (
              <div style={{ padding:"12px 14px 14px", borderTop:`1px solid ${c.div}` }}>
                <SectionLabel>Progress</SectionLabel>
                <MiniChart points={history} color={m.color} height={64} />
                <div style={{ display:"flex", flexWrap:"wrap", gap:5, marginTop:10 }}>
                  {history.slice(-6).reverse().map(p => (
                    <div key={p.date} style={{ background:c.inputBg, border:`1px solid ${c.inputBorder}`, borderRadius:7, padding:"4px 9px", fontSize:11 }}>
                      <span style={{ color:c.ts }}>{p.date.slice(5)} </span>
                      <span style={{ color:m.color, fontWeight:700 }}>{p.val}{m.unit}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </>
  );
}

