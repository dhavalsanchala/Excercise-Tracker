          {isCustomWeek && <span style={{ marginLeft:8, fontSize:10, color:c.accent, fontWeight:700, background:c.accent+"20", padding:"2px 6px", borderRadius:5 }}>CUSTOM</span>}
        </div>
        <button onClick={toggleRest} style={{
          padding:"5px 11px", borderRadius:8,
          border:`1px solid ${dayIsRest ? c.tm : c.inputBorder}`,
          background: dayIsRest ? c.tm+"20" : "transparent",
          color: dayIsRest ? c.tp : c.ts,
          fontSize:11, fontWeight:700, cursor:"pointer", flexShrink:0,
