// FILE: storage.js — persistence + schema migrations
// ═══════════════════════════════════════════════════════════════════
//
// Storage shape (v3):
// {
//   __version: 3,
//   weeks: {
//     "2026-W18": { plan: { MON:[{name,target}], TUE:[...], ..., SUN:[...] } }
//   },
//   days: {
//     "2026-05-01": {
//       exercises: { "Hack Squats": { sets:[...], tech:null, supersetWith:null } },
//       measurements: { bodyWeight:"75.5", chest:"100", ... }
//     }
//   }
// }
//
// Notes:
// - A week without an entry in `weeks` falls back to the default WORKOUT_PLAN.
// - A week with an explicit plan ({ MON:[], TUE:[], ... }) shows whatever the user put there
//   (including an empty list = blank week, no exercises planned).
//
// v2 shape (no weeks field):
// { __version: 2, days: { "2026-05-01": { exercises:{}, measurements:{} } } }
//
// v1 (no __version): { "2026-05-01": { "Hack Squats": {...}, "__measurements": {...} } }

function migrateV1ToV2(raw) {
  if (raw && typeof raw === "object" && !Array.isArray(raw) && (raw.__version === 2 || raw.__version === 3)) {
    if (raw.days && typeof raw.days === "object" && !Array.isArray(raw.days)) return raw;
    return { __version: 2, days: {} };
  }
  if (!raw || typeof raw !== "object" || Array.isArray(raw)) {
    return { __version: 2, days: {} };
  }

  const days = {};
  for (const [k, v] of Object.entries(raw)) {
    if (k === "__version" || k === "days" || k === "weeks") continue;
    if (!v || typeof v !== "object" || Array.isArray(v)) continue;
    const day = { exercises: {}, measurements: {} };
    for (const [exName, exData] of Object.entries(v)) {
      if (exName === "__measurements") {
        if (exData && typeof exData === "object" && !Array.isArray(exData)) {
          day.measurements = { ...exData };
        }
      } else if (exData && typeof exData === "object" && !Array.isArray(exData)) {
        day.exercises[exName] = {
          sets: Array.isArray(exData.sets) ? exData.sets : [],
          tech: exData.tech ?? null,
          supersetWith: exData.supersetWith ?? null,
        };
      }
    }
    days[k] = day;
  }
  return { __version: 2, days };
}

function migrateV2ToV3(v2) {
  if (v2 && v2.__version === 3) return v2;
  return {
    __version: 3,
    weeks: (v2 && typeof v2.weeks === "object" && !Array.isArray(v2.weeks)) ? v2.weeks : {},
    days: (v2 && typeof v2.days === "object" && !Array.isArray(v2.days)) ? v2.days : {},
  };
}

function migrateToLatest(raw) {
  // chain migrations: any → v2 → v3
  return migrateV2ToV3(migrateV1ToV2(raw));
}

async function loadStore() {
  try {
    if (typeof window === "undefined" || !window.storage) {
      console.warn("window.storage unavailable; running in-memory only");
      return { __version: SCHEMA_VERSION, weeks: {}, days: {} };
    }
    let r = null;
    try { r = await window.storage.get(STORAGE_KEY); }
    catch (getErr) {
      console.log("storage.get threw (treating as empty):", getErr?.message);
      return { __version: SCHEMA_VERSION, weeks: {}, days: {} };
    }
    if (!r || !r.value) return { __version: SCHEMA_VERSION, weeks: {}, days: {} };

    let raw;
    try { raw = JSON.parse(r.value); }
    catch (parseErr) {
      console.error("loadStore: JSON parse failed", parseErr);
      return null;
    }

    const migrated = migrateToLatest(raw);
    // Persist migration if shape changed
    if (!raw || typeof raw !== "object" || raw.__version !== SCHEMA_VERSION) {
      try { await window.storage.set(STORAGE_KEY, JSON.stringify(migrated)); }
      catch (saveErr) { console.warn("migration save failed (continuing):", saveErr); }
    }
    return migrated;
  } catch (err) {
    console.error("loadStore failed:", err);
    return null;
  }
}

async function saveStore(store) {
  try {
    if (typeof window === "undefined" || !window.storage) return;
    await window.storage.set(STORAGE_KEY, JSON.stringify(store));
  } catch (err) { console.error("saveStore failed:", err); }
}

async function clearStore() {
  try {
    if (typeof window === "undefined" || !window.storage) return;
    await window.storage.delete?.(STORAGE_KEY);
  } catch {}
}

const getDay = (store, dk) => store.days[dk] || { exercises: {}, measurements: {} };
const getExercise = (store, dk, name) => getDay(store, dk).exercises[name] || { sets:[], tech:null, supersetWith:null };
const getMeasurement = (store, dk, key) => getDay(store, dk).measurements[key] ?? "";

// Plan resolution: explicit week plan if present, else fall back to default WORKOUT_PLAN
function getPlanForWeek(store, wk) {
  const weekEntry = store.weeks?.[wk];
  if (weekEntry && weekEntry.plan && typeof weekEntry.plan === "object") return weekEntry.plan;
  return WORKOUT_PLAN; // default fixed plan
}
function getPlanForDate(store, dk) {
  return getPlanForWeek(store, getWeekKeyFromDateKey(dk));
}
function getDayPlan(store, dk) {
  const plan = getPlanForDate(store, dk);
  const dow = getDOWFromKey(dk);
  return plan[dow] || [];
}
function isWeekCustomized(store, wk) {
  return !!store.weeks?.[wk]?.plan;
}

// Per-day focus label: explicit week override → DAY_FOCUS default
function getDayFocus(store, wk, dow) {
  const override = store.weeks?.[wk]?.focus?.[dow];
  if (typeof override === "string") return override; // explicit value (incl. empty string)
  return DAY_FOCUS[dow] || "";
}

// Per-day rest flag: explicit week override → false (default plan never marks days as rest;
// "rest day" was previously implicit via empty-exercises-list). Now it's an explicit flag.
function isDayRest(store, wk, dow) {
  const override = store.weeks?.[wk]?.rest?.[dow];
  if (typeof override === "boolean") return override;
  // Default: a day is implicitly "rest-ish" if the default plan has no exercises (e.g. SUN)
  return (WORKOUT_PLAN[dow] || []).length === 0;
}

function dayHasData(day) {
  if (!day) return false;
  if (Object.values(day.exercises || {}).some(ex => ex.sets?.length > 0)) return true;
  if (Object.values(day.measurements || {}).some(v => v !== "" && v != null)) return true;
  return false;
}

function dayTotalVolume(day) {
  if (!day) return 0;
  return Object.values(day.exercises || {}).reduce(
    (a, ex) => a + (ex.sets || []).reduce((b, s) => b + (num(s.weight) * num(s.reps)), 0),
    0
  );
}

