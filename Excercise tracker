function MiniChart({ points, color, height }) {
  const H = height || 64;
  if (points.length < 2) return <div style={{ color:c.tm, fontSize:12, textAlign:"center", padding:"16px 0" }}>Need 2+ entries to chart</div>;
  const W = 320;
  const vals = points.map(p => p.val);
  const mn = Math.min(...vals), mx = Math.max(...vals);
  const range = mx - mn;
  const flat = range === 0;
  const px = i => (i / (points.length - 1)) * (W - 24) + 12;
  const py = v => flat ? H/2 : H - ((v - mn) / range) * (H - 16) - 4;
  return (
    <svg width="100%" viewBox={`0 0 ${W} ${H + 22}`} style={{ overflow:"visible" }}>
      <polyline fill="none" stroke={color} strokeWidth="2" strokeLinejoin="round"
        points={points.map((p, i) => `${px(i)},${py(p.val)}`).join(" ")} />
      {points.map((p, i) => (
        <g key={i}>
          <circle cx={px(i)} cy={py(p.val)} r={3} fill={color} />
          {(i === 0 || i === points.length - 1 || points.length <= 5) && (
            <>
              <text x={px(i)} y={py(p.val) - 9} textAnchor="middle" fill={color} fontSize={10} fontWeight="700">{p.val}</text>
              <text x={px(i)} y={H + 19} textAnchor="middle" fill={c.ts} fontSize={9}>{p.date.slice(5)}</text>
            </>
          )}
        </g>
      ))}
    </svg>
  );
}

